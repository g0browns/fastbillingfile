# Option B: provide login credentials (token will be fetched automatically)
WHEN_I_WORK_API_KEY=
WHEN_I_WORK_EMAIL=
WHEN_I_WORK_PASSWORD=
WHEN_I_WORK_BASE_URL=https://api.wheniwork.com/2
WHEN_I_WORK_USER_ID=
JOTFORM_API_KEY=
JOTFORM_BASE_URL=https://api.jotform.com
JOTFORM_FORM_ID=

# Optional runtime controls
AUDIT_OUTPUT_DIR=output
AUDIT_TIMEZONE=UTC
AUDIT_REQUEST_TIMEOUT_SECONDS=30
AUDIT_BILLABLE_ONLY=true
